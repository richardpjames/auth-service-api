// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  displayName         String
  admin               Boolean              @default(false)
  createdAt           DateTime             @default(now())
  disabledAt          DateTime?
  updatedAt           DateTime             @updatedAt
  authSessions        AuthSession[]
  authCodes           AuthCode[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
}

model AuthSession {
  id         String   @id @default(cuid())
  sessionKey String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ClientApp {
  id           String @id @default(cuid())
  clientId     String @unique
  clientSecret String
  name         String
  redirectUri  String

  codes         AuthCode[]
  refreshTokens RefreshToken[]
}

model AuthCode {
  id          String    @id @default(cuid())
  code        String    @unique
  userId      String
  clientAppId String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientApp ClientApp @relation(fields: [clientAppId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientAppId])
  @@index([expiresAt])
}

model RefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  clientAppId String
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientApp ClientApp @relation(fields: [clientAppId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientAppId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
